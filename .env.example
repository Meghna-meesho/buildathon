# Copy this file to `.env` and fill in your values. `.env` is gitignored — never commit real keys.
# Without any of these set, the app runs in statistical mode (no AI, fully functional).

# --- Option A: OpenAI-compatible gateway (e.g. Bifrost) for AI-written RCA narratives ---
LLM_GATEWAY_URL=https://your-gateway-host/v1/chat/completions
LLM_API_KEY=your-gateway-api-key
LLM_MODEL=gpt-4o

# --- Option B: Anthropic directly (used only if the gateway above is not set) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# On Hugging Face Spaces: do NOT commit these — add LLM_API_KEY as a Space *secret*
# and LLM_GATEWAY_URL / LLM_MODEL as Space *variables*.
